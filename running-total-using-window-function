CREATE TABLE Employee (
    emp_id INT PRIMARY KEY,
    emp_name VARCHAR(50),
    salary INT
);

INSERT INTO Employee VALUES
(1,'Alice',50000),
(2,'Bob',70000),
(3,'Charlie',60000),
(4,'David',80000);

SELECT emp_name,
       salary,
       SUM(salary) OVER(
           ORDER BY emp_id
       ) AS running_total
FROM Employee;

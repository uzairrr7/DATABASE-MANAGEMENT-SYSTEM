-- ATOMICITY: Transfer amount between accounts (both succeed or both fail)
BEGIN TRANSACTION;

UPDATE accounts 
SET balance = balance - 5000 
WHERE account_id = 101;

UPDATE accounts 
SET balance = balance + 5000 
WHERE account_id = 102;

-- If any error occurs, both statements are rolled back
COMMIT; -- or ROLLBACK on error

-- ISOLATION: Prevent dirty reads using transaction isolation levels
SET TRANSACTION ISOLATION LEVEL SERIALIZABLE;

BEGIN TRANSACTION;
SELECT * FROM accounts WHERE account_id = 101; -- Locked until commit
-- Other transactions cannot modify this row
COMMIT;

-- CONSISTENCY: Constraint validation
ALTER TABLE accounts 
ADD CONSTRAINT check_balance CHECK (balance >= 0);

-- If balance goes negative, transaction fails automatically

-- DURABILITY: Once committed, data is permanently stored
-- (Handled by DBMS, persisted to disk)

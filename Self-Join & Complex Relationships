-- Create employees table with manager relationship
CREATE TABLE emp_details (
    emp_id INT PRIMARY KEY,
    emp_name VARCHAR(100),
    salary DECIMAL(10, 2),
    department VARCHAR(50),
    manager_id INT,
    FOREIGN KEY (manager_id) REFERENCES emp_details(emp_id)
);


-- 2 (Priya Singh) & 3 (Vikram Kumar) | IT | 80000 | Both report to Rahul
-- 6 (Neha Gupta) & 9 (Ishita Verma) | IT | 60000 | Both report to Priya
-- (Rohan Singh 65000 - only one in IT with this salary, no pair)

-- KEY CONCEPT: 
-- e1.emp_id < e2.emp_id ensures we don't get duplicate pairs
-- e.g., (2,3) and (3,2) - we only get (2,3)

-- ========== QUERY 2: FIND EMPLOYEES EARNING MORE THAN THEIR MANAGER ==========
-- Find cases where subordinate salary > manager salary (compensation anomaly)

SELECT 
    e.emp_id as employee_id,
    e.emp_name as employee_name,
    e.salary as employee_salary,
    e.department as employee_dept,
    m.emp_id as manager_id,
    m.emp_name as manager_name,
    m.salary as manager_salary,
    m.department as manager_dept,
    (e.salary - m.salary) as salary_difference,
    ROUND(((e.salary - m.salary) / m.salary * 100), 2) as percentage_higher
FROM emp_details e
INNER JOIN emp_details m ON e.manager_id = m.emp_id
WHERE e.salary > m.salary
ORDER BY salary_difference DESC;

-- OUTPUT:
-- 5 (Arjun Das) earns 65000, manager Priya earns 80000 → NO (manager earns more)
-- (No employee earns more than their manager in this dataset)
-- This query would be useful in real scenarios to identify anomalies

-- ========== QUERY 3: ALL MANAGER-SUBORDINATE PAIRS WITH SALARY COMPARISON ==========
-- Show all relationships with salary dynamics

SELECT 
    m.emp_id as manager_id,
    m.emp_name as manager_name,
    m.salary as manager_salary,
    m.department as manager_dept,
    e.emp_id as subordinate_id,
    e.emp_name as subordinate_name,
    e.salary as subordinate_salary,
    e.department as subordinate_dept,
    (e.salary - m.salary) as salary_diff,
    CASE 
        WHEN e.salary > m.salary THEN '⚠️ Subordinate earns MORE'
        WHEN e.salary = m.salary THEN '⚠️ Same salary'
        ELSE '✓ Manager earns more'
    END as salary_comparison,
    ROUND((e.salary / m.salary * 100), 2) as subordinate_salary_percent
FROM emp_details m
INNER JOIN emp_details e ON m.emp_id = e.manager_id
ORDER BY m.emp_id, e.salary DESC;


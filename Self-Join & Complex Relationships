-- ========== QUERY 1: FIND EMPLOYEE PAIRS WITH SAME SALARY IN SAME DEPARTMENT ==========
-- Find all pairs of employees who have identical salaries in the same department

SELECT DISTINCT
    e1.emp_id as employee_1_id,
    e1.emp_name as employee_1_name,
    e2.emp_id as employee_2_id,
    e2.emp_name as employee_2_name,
    e1.salary,
    e1.department,
    e1.manager_id as emp_1_manager_id,
    e2.manager_id as emp_2_manager_id
FROM emp_details e1
INNER JOIN emp_details e2 ON e1.salary = e2.salary 
                           AND e1.department = e2.department
                           AND e1.emp_id < e2.emp_id  -- Avoid duplicate pairs
ORDER BY e1.department, e1.salary DESC, employee_1_id;


CREATE TABLE Employee (
    emp_id INT PRIMARY KEY,
    emp_name VARCHAR(50),
    salary INT
);

INSERT INTO Employee VALUES
(1,'Alice',50000),
(2,'Bob',70000),
(3,'Charlie',90000),
(4,'David',70000),
(5,'Eva',85000);

SELECT emp_name,
       salary
FROM (
    SELECT emp_name,
           salary,
           DENSE_RANK() OVER (ORDER BY salary DESC) AS rnk
    FROM Employee
) ranked
WHERE rnk = 2;

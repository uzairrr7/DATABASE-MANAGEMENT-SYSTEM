-- VARIATION 3: Count depth and show team size
WITH RECURSIVE org_hierarchy AS (
    SELECT 
        employee_id,
        employee_name,
        job_title,
        manager_id,
        1 as level
    FROM employees
    WHERE manager_id IS NULL
    
    UNION ALL
    
    SELECT 
        e.employee_id,
        e.employee_name,
        e.job_title,
        e.manager_id,
        oh.level + 1
    FROM employees e
    INNER JOIN org_hierarchy oh ON e.manager_id = oh.employee_id
)
SELECT 
    employee_id,
    employee_name,
    job_title,
    level,
    (SELECT COUNT(*) FROM org_hierarchy oh2 
     WHERE oh2.manager_id = oh1.employee_id) as direct_reports
FROM org_hierarchy oh1
ORDER BY level, employee_name;

-- OUTPUT:
-- 1 | Rajesh Kumar | CEO             | 1 | 2 direct reports
-- 2 | Priya Sharma | VP Engineering  | 2 | 2 direct reports
-- 3 | Amit Patel   | VP Sales        | 2 | 1 direct report
-- 4 | Neha Singh   | Senior Dev      | 3 | 1 direct report
-- 5 | Vikram Joshi | Developer       | 3 | 0 direct reports
-- 6 | Ananya Das   | Developer       | 4 | 0 direct reports
-- 7 | Rohan Gupta  | Sales Manager   | 3 | 1 direct report
-- 8 | Zara Khan    | Sales Executive | 4 | 0 direct reports


-- Step 3: Recursive CTE - Find complete manager chain for an employee
WITH RECURSIVE manager_chain AS (
    -- BASE CASE: Start with the employee we're interested in
    SELECT 
        employee_id,
        employee_name,
        job_title,
        manager_id,
        salary,
        1 as level,
        employee_name as hierarchy_path
    FROM employees
    WHERE employee_id = 6  -- Find chain for Ananya Das (employee_id = 6)
    
    UNION ALL
    
    -- RECURSIVE CASE: Keep going up the hierarchy
    SELECT 
        e.employee_id,
        e.employee_name,
        e.job_title,
        e.manager_id,
        e.salary,
        mc.level + 1,
        CONCAT(e.employee_name, ' → ', mc.hierarchy_path)
    FROM employees e
    INNER JOIN manager_chain mc ON e.employee_id = mc.manager_id
)
SELECT 
    employee_id,
    employee_name,
    job_title,
    salary,
    level,
    hierarchy_path
FROM manager_chain
ORDER BY level;


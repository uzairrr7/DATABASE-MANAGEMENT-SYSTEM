-- VARIATION 1: Show full hierarchy for all employees
WITH RECURSIVE manager_chain AS (
    SELECT 
        employee_id,
        employee_name,
        job_title,
        manager_id,
        1 as level,
        CAST(employee_name AS CHAR(500)) as hierarchy_path
    FROM employees
    WHERE manager_id IS NULL  -- Start with CEO
    
    UNION ALL
    
    SELECT 
        e.employee_id,
        e.employee_name,
        e.job_title,
        e.manager_id,
        mc.level + 1,
        CONCAT(mc.hierarchy_path, ' → ', e.employee_name)
    FROM employees e
    INNER JOIN manager_chain mc ON e.manager_id = mc.employee_id
)
SELECT 
    REPEAT('  ', level - 1) as indent,
    employee_name,
    job_title,
    level as depth
FROM manager_chain
ORDER BY hierarchy_path;

-- OUTPUT (Shows tree structure):
-- Rajesh Kumar (CEO) - Level 1
--   Priya Sharma (VP Engineering) - Level 2
--     Neha Singh (Senior Developer) - Level 3
--       Ananya Das (Developer) - Level 4
--     Vikram Joshi (Developer) - Level 3
--   Amit Patel (VP Sales) - Level 2
--     Rohan Gupta (Sales Manager) - Level 3
--       Zara Khan (Sales Executive) - Level 4


-- VARIATION 2: Get direct and indirect subordinates for a manager
WITH RECURSIVE subordinates AS (
    -- BASE CASE: Start with a specific manager
    SELECT 
        employee_id,
        employee_name,
        job_title,
        manager_id,
        1 as level
    FROM employees
    WHERE employee_id = 2  -- Find subordinates of Priya (VP Engineering)
    
    UNION ALL
    
    -- RECURSIVE CASE: Find all employees under this manager
    SELECT 
        e.employee_id,
        e.employee_name,
        e.job_title,
        e.manager_id,
        s.level + 1
    FROM employees e
    INNER JOIN subordinates s ON e.manager_id = s.employee_id
)
SELECT 
    employee_id,
    employee_name,
    job_title,
    level,
    CASE 
        WHEN level = 1 THEN 'Manager'
        WHEN level = 2 THEN 'Direct Report'
        ELSE 'Indirect Report'
    END as relation_type
FROM subordinates
ORDER BY level, employee_name;

-- OUTPUT (Shows Priya's team):
-- 2 | Priya Sharma   | VP Engineering  | 1 | Manager
-- 4 | Neha Singh     | Senior Developer| 2 | Direct Report
-- 5 | Vikram Joshi   | Developer       | 2 | Direct Report
-- 6 | Ananya Das     | Developer       | 3 | Indirect Report


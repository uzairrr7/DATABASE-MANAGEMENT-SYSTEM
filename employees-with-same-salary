CREATE TABLE Employee (
    emp_id INT PRIMARY KEY,
    emp_name VARCHAR(50),
    salary INT
);

INSERT INTO Employee VALUES
(1,'Alice',50000),
(2,'Bob',70000),
(3,'Charlie',70000),
(4,'David',60000);

SELECT e1.emp_name,
       e2.emp_name,
       e1.salary
FROM Employee e1
JOIN Employee e2
ON e1.salary = e2.salary
AND e1.emp_id < e2.emp_id;

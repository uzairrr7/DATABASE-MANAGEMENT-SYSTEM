SELECT e.emp_name AS employee,
       m.emp_name AS manager,
       e.hire_date,
       m.hire_date AS manager_hire_date
FROM Employee e
JOIN Employee m
ON e.manager_id = m.emp_id
WHERE e.hire_date > m.hire_date;

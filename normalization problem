-- BEFORE NORMALIZATION (Un-normalized with repeating groups)
-- Employee table with multiple phones and addresses in same record
-- BAD DESIGN - violates 1NF

-- AFTER NORMALIZATION - Split into 3NF

-- 1. Employees Table (Main entity)
CREATE TABLE employees (
    employee_id INT PRIMARY KEY,
    employee_name VARCHAR(100),
    department VARCHAR(50)
);

-- 2. Employee Phone Numbers (Repeating group handled)
CREATE TABLE employee_phones (
    phone_id INT PRIMARY KEY,
    employee_id INT,
    phone_number VARCHAR(15),
    phone_type VARCHAR(20), -- Mobile, Office, Home
    FOREIGN KEY (employee_id) REFERENCES employees(employee_id)
);

-- 3. Employee Addresses (Repeating group handled)
CREATE TABLE employee_addresses (
    address_id INT PRIMARY KEY,
    employee_id INT,
    street VARCHAR(100),
    city VARCHAR(50),
    state VARCHAR(50),
    postal_code VARCHAR(10),
    address_type VARCHAR(20), -- Home, Office
    FOREIGN KEY (employee_id) REFERENCES employees(employee_id)
);

-- QUERY 1: Get all phone numbers for employee_id = 5
SELECT 
    e.employee_name,
    ep.phone_number,
    ep.phone_type
FROM employees e
JOIN employee_phones ep ON e.employee_id = ep.employee_id
WHERE e.employee_id = 5;

-- QUERY 2: Get all employees from city = 'Mumbai'
SELECT DISTINCT
    e.employee_id,
    e.employee_name,
    ea.city
FROM employees e
JOIN employee_addresses ea ON e.employee_id = ea.employee_id
WHERE ea.city = 'Mumbai';

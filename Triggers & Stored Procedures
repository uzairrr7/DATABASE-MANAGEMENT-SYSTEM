-- -------- STORED PROCEDURE: Process Monthly Salary --------
CREATE PROCEDURE process_monthly_salary(IN emp_id INT, OUT processed_status VARCHAR(100))
BEGIN
    DECLARE emp_salary DECIMAL(10, 2);
    DECLARE tax_amount DECIMAL(10, 2);
    DECLARE net_salary DECIMAL(10, 2);
    DECLARE emp_name VARCHAR(100);
    
    -- Get employee details
    SELECT employee_name, salary INTO emp_name, emp_salary
    FROM employees
    WHERE employee_id = emp_id;
    
    IF emp_salary IS NULL THEN
        SET processed_status = 'Employee not found';
        SELECT processed_status;
    ELSE
        -- Calculate tax (assume 10% for simplicity)
        SET tax_amount = emp_salary * 0.10;
        SET net_salary = emp_salary - tax_amount;
        
        -- Log the transaction
        INSERT INTO salary_audit (employee_id, old_salary, new_salary, changed_by)
        VALUES (emp_id, emp_salary, net_salary, 'PAYROLL_SYSTEM');
        
        -- Update bank transfer (simulated)
        SET processed_status = CONCAT(
            'Salary Processed for ', emp_name, 
            ' | Gross: ', emp_salary, 
            ' | Tax: ', tax_amount, 
            ' | Net: ', net_salary
        );
        
        SELECT processed_status;
    END IF;
END;
 

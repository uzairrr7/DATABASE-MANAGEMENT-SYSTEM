CREATE TABLE Employee (
    emp_id INT PRIMARY KEY,
    emp_name VARCHAR(50),
    department VARCHAR(30),
    salary INT
);

INSERT INTO Employee VALUES
(1,'Alice','HR',50000),
(2,'Bob','HR',70000),
(3,'Charlie','HR',60000),
(4,'David','IT',90000),
(5,'Eva','IT',85000),
(6,'Frank','IT',75000);

SELECT department,
       emp_name,
       salary
FROM (
    SELECT *,
           DENSE_RANK() OVER(PARTITION BY department ORDER BY salary DESC) AS rnk
    FROM Employee
) t
WHERE rnk = 2;
